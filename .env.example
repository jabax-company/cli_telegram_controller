# ── OBLIGATORIO ───────────────────────────────────────────────────────────────

# Token del bot (obtenido de @BotFather en Telegram)
TELEGRAM_TOKEN=your_telegram_bot_token

# Tu ID numérico de Telegram (obtén con @userinfobot)
TELEGRAM_USER_ID=123456789

# ── MOTOR DE IA ───────────────────────────────────────────────────────────────

# Motor a usar: "claude" (por defecto) o "codex" (OpenAI Codex CLI)
# AI_ENGINE=claude

# Modelo de Codex (solo si AI_ENGINE=codex). Ejemplos: o4-mini, o3
# CODEX_MODEL=o4-mini

# ── AUDIO (faster-whisper) ────────────────────────────────────────────────────

# Tamaño del modelo: tiny / base / small / medium / large-v3
# WHISPER_MODEL=small

# Dispositivo: auto / cpu / cuda
# WHISPER_DEVICE=auto

# Tipo de cómputo: int8 / int8_float16 / float16 / float32
# WHISPER_COMPUTE_TYPE=int8

# Idioma principal de transcripción (ISO 639-1)
# WHISPER_PRIMARY_LANGUAGE=es

# Detectar idioma automáticamente si falla el idioma principal
# WHISPER_ALLOW_AUTO_FALLBACK=true

# ── DIRECTORIOS ───────────────────────────────────────────────────────────────

# Directorio de trabajo inicial (por defecto: raíz del bot)
# INITIAL_DIR=~/projects

# ── COMPORTAMIENTO ────────────────────────────────────────────────────────────

# Mejorar prompts de texto/audio con IA antes de ejecutar (añade ~5s de latencia)
# PROMPT_ENHANCE_ENABLED=false

# Bloquear comandos destructivos (rm, del, git reset --hard, etc.)
# SAFE_MODE=true

# Restringir la IA al directorio actual
# RESTRICT_PATHS=false

# Parar sesión automáticamente tras N segundos de inactividad (30 min por defecto)
# INACTIVITY_TIMEOUT_SECS=1800
# INACTIVITY_CHECK_SECS=30

# Icono en bandeja del sistema (Windows, requiere pystray + Pillow)
# TRAY_ICON_ENABLED=true

# Límites de historial de imágenes
# MAX_IMAGE_HISTORY=50
# MAX_PENDING_IMAGES=10

# ── SERVIDOR CLOUDFLARE TUNNEL ────────────────────────────────────────────────

# Comandos y directorios para /server fullstack (si no se detectan automáticamente)
# FULLSTACK_FRONT_CMD=npm run dev
# FULLSTACK_FRONT_DIR=frontend
# FULLSTACK_BACK_CMD=uv run python main.py
# FULLSTACK_BACK_DIR=backend

# Archivo de configuración del backend (Claude lo mantiene actualizado)
# BACKEND_RUNBOOK_FILE=.claude/backend_run.json
# ENFORCE_BACKEND_RUNBOOK=true

# Puerto para modo estático
# SERVE_PORT=8080

# ── SEGURIDAD ─────────────────────────────────────────────────────────────────

# Patrones extra a bloquear antes de enviar a la IA (separados por coma)
# Los patrones integrados ya cubren: rm -rf, dd if=, mkfs, fork bombs, curl|bash, etc.
# BLOCKED_PATTERNS=drop database,truncate table
