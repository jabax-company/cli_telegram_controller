# ── Required ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token

# Your numeric Telegram user ID (use @userinfobot to find it)
TELEGRAM_USER_ID=123456789

# ── Optional ──────────────────────────────────────────────────────────────────

# Anthropic API key — used to generate AI status summaries every 5 minutes
# during long sessions (via Claude Haiku, costs fractions of a cent per summary).
# If unset or the call fails, the bot falls back to showing the last 8 raw output lines.
# Claude Code already needs this key, so it is likely set in your environment already.
# ANTHROPIC_API_KEY=sk-ant-...

# Local faster-whisper model for voice/audio transcription.
# Can be a model name (tiny/base/small/medium/large-v3) or a local model path.
# WHISPER_MODEL=small

# Device: auto/cpu/cuda
# WHISPER_DEVICE=auto

# Compute type examples: int8, int8_float16, float16, float32
# WHISPER_COMPUTE_TYPE=int8

# Decoding options
# WHISPER_BEAM_SIZE=5
# WHISPER_VAD_FILTER=true

# Preferred language for transcription (default: Spanish).
# If audio is in another language (e.g. English), enable auto fallback.
# WHISPER_PRIMARY_LANGUAGE=es
# WHISPER_ALLOW_AUTO_FALLBACK=true

# Default working directory when the bot starts (default: ~)
# INITIAL_DIR=~/projects

# Set to "true" to restrict Claude Code to the current project directory.
# The bot auto-detects the right CLI flag (e.g. --add-dir or --allowedPaths).
# Off by default for flexibility (same as running claude in your terminal).
# RESTRICT_PATHS=false

# Safe mode blocks destructive shell tools (rm/del/Remove-Item/git clean/reset --hard)
# but does not force path restriction by itself.
# SAFE_MODE=true

# Auto-shutdown if no Telegram interaction happens for N seconds (default: 900 = 15 min)
# INACTIVITY_TIMEOUT_SECS=900
# INACTIVITY_CHECK_SECS=30

# Image memory limits (images are stored in <repo>/images)
# MAX_IMAGE_HISTORY=50
# MAX_PENDING_IMAGES=10

# Show a Windows tray icon while bot is active (requires pystray + Pillow)
# TRAY_ICON_ENABLED=true

# Optional commands for /server fullstack auto-start.
# If set, the bot will use these commands when frontend/backend ports are down.
# Paths can be absolute or relative to current project directory.
# FULLSTACK_FRONT_CMD=npm run dev
# FULLSTACK_FRONT_DIR=frontend
# FULLSTACK_BACK_CMD=uv run python main.py
# FULLSTACK_BACK_DIR=backend

# Backend runbook file used by /server fullstack when FULLSTACK_BACK_CMD is not set.
# Claude is instructed to keep this file updated when backend/API changes are made.
# BACKEND_RUNBOOK_FILE=.claude/backend_run.json
# ENFORCE_BACKEND_RUNBOOK=true

# Comma-separated extra patterns to block before sending to Claude Code
# Built-in list already covers: rm -rf /, dd if=, mkfs, fork bombs, curl|bash, etc.
# BLOCKED_PATTERNS=drop database,truncate table
