# ── Telegram ─────────────────────────────────────────────────────────────────
# Token del bot (obtenido de @BotFather, solo el token; sin URL y sin prefijo "bot")
TELEGRAM_TOKEN=your_telegram_bot_token

# Tu Telegram user ID numérico (usa @userinfobot para obtenerlo)
TELEGRAM_USER_ID=123456789

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# Modelo para el refinamiento (haiku = barato; puedes cambiarlo)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token con permisos: repo + workflow
GH_PAT=ghp_...

# Repositorio donde vive ESTE bot (donde está el workflow agente.yml)
GITHUB_WORKFLOW_REPO_OWNER=tu_usuario
GITHUB_WORKFLOW_REPO_NAME=claude_code_bot
